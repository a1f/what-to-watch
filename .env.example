# =============================================================
# What to Watch -- shared config template.
# Copy to .env and fill in real values; never commit your .env.
# Keys derive from DESIGN.md (§6 sources, §11 model, §12 stack).
# =============================================================

# --- App ---
# Default region for release-date / availability lookups.
REGION=US
# FastAPI origin; the Next BFF calls this server-to-server.
API_BASE_URL=http://localhost:8000
# Public web origin (exposed to the browser).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Postgres; pgvector reserved for later) ---
# For LOCAL, NON-DOCKER runs only (host `localhost`). Under compose this URL is
# IGNORED: the api/worker get an in-network URL built from POSTGRES_* (host `db`).
# Scheme is pinned to the psycopg3 driver (the one we install).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/what_to_watch
# Credentials for the compose `db` service. Compose builds the in-network
# DATABASE_URL from these (postgresql+psycopg://USER:PASSWORD@db:5432/DB), so the
# api/worker reach Postgres at host `db` regardless of the value above.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=what_to_watch

# --- Data sources (TVmaze needs no key) ---
TMDB_API_KEY=your-tmdb-api-key
OMDB_API_KEY=your-omdb-api-key

# --- Auth: Google OAuth via Auth.js; signed JWT forwarded to FastAPI ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
AUTH_SECRET=change-me-to-a-random-string
AUTH_URL=http://localhost:3000
BFF_JWT_SECRET=change-me-shared-secret-for-next-to-fastapi

# --- AI & web grounding ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5
SEARXNG_URL=http://localhost:8080

# --- Notifications: Apprise fans out to email + opt-in push channels ---
# Email is dispatched through Apprise; the sender is set on the mailto:// URL
# via the ?from= query param (no standalone SMTP_* vars needed).
APPRISE_URLS=mailto://user:password@smtp.example.com?from=what-to-watch@example.com
